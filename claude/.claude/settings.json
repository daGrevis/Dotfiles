{
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "WebFetch *",
      "WebSearch *",
      "mcp__*"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); sid=$(echo \"$input\" | jq -r '.session_id // empty'); date +%s > /tmp/.claude-prompt-start-${sid:-default}"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/sh/claude-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/sh/claude-notify.sh"
          }
        ]
      }
    ]
  }
}
